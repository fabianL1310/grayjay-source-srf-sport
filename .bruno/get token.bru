meta {
  name: get token
  type: http
  seq: 5
}

get {
  url: https://tp.srgssr.ch/akahd/token?acl={{acl}}
  body: none
  auth: inherit
}

params:query {
  acl: {{acl}}
}

script:pre-request {
  bru.setVar("acl", "/" + bru.getVar("hlsPath").replace(/[^\/]*$/, "*"))
}

script:post-response {
  bru.setVar("authParams", res.body.token.authparams.replace(/^hdnts=/,""))
}

settings {
  encodeUrl: true
  timeout: 0
}
