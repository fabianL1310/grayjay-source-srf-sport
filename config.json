{
  "name": "SRF Sport",
  "description": "Plugin for events broadcasted by SRF Sport",
  "author": "Fabian",
  "authorUrl": "http://github.com/fabianL1310",
  "platformUrl": "https://www.srf.ch/sport",
  "sourceUrl": "https://raw.githubusercontent.com/fabianL1310/grayjay-source-srf-sport/refs/heads/main/config.json",
  "repositoryUrl": "https://github.com/fabianL1310/grayjay-source-srf-sport",
  "scriptUrl": "./dist/script.js",
  "version": 5,
  "iconUrl": "./icon.png",
  "id": "3eed670d-c893-4688-9ac8-cb02a0c13f3e",
  "packages": ["Http"],
  "allowEval": false,
  "allowUrls": [
    "sport.api.swisstxt.ch",
    "event.api.swisstxt.ch",
    "tp.srgssr.ch",
    "srgssrlsvech-d.akamaized.net",
    "raw.githubusercontent.com"
  ],
  "settings": [
    {
      "variable": "showLiveFirst",
      "name": "Show live events first",
      "description": "Show events that are currently live at the top",
      "type": "Boolean",
      "default": "true"
    }
  ]
}
